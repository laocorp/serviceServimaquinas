# ───────────────────────────────────────────────────────────────────────────────
# Variables de Entorno - SistemaServimaquinas
# Copia este archivo como ".env" y rellena los valores reales
# ───────────────────────────────────────────────────────────────────────────────

# ── Base de Datos (Neon PostgreSQL) ──────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# ── NextAuth.js ───────────────────────────────────────────────────────────────
# Genera un secreto seguro con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET="TU_SECRETO_GENERADO_AQUI"
NEXTAUTH_URL="https://TU_DOMINIO.com"
AUTH_TRUST_HOST=true
