generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  TECNICO
  RECEPCION
  CLIENTE
}

enum OrderStatus {
  PENDIENTE
  EN_REVISION
  EN_REPARACION
  REPARADO
  ENTREGADO
  CANCELADO
}

enum Priority {
  BAJA
  MEDIA
  ALTA
  URGENTE
}

model User {
  id            String      @id @default(cuid())
  name          String?
  email         String?     @unique
  password      String?
  role          Role        @default(TECNICO)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  workOrders    WorkOrder[] @relation("TechnicianOrders")
  createdOrders WorkOrder[]   @relation("CreatorOrders")
  reports       WorkReport[]
}

model Customer {
  id         String      @id @default(cuid())
  name       String
  email      String?     @unique
  phone      String?
  address    String?
  dni        String?     @unique
  isVIP      Boolean     @default(false)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  workOrders WorkOrder[]
}

model WorkOrder {
  id             String          @id @default(cuid())
  orderNumber    String          @unique
  customerId     String
  technicianId   String?
  creatorId      String
  status         OrderStatus     @default(PENDIENTE)
  priority       Priority        @default(MEDIA)
  equipment      String
  brand          String?
  model          String?
  serialNumber   String?
  description    String
  observations   String?
  entryDate      DateTime        @default(now())
  estimatedDate  DateTime?
  deliveryDate   DateTime?
  laborCost      Decimal         @default(0) @db.Decimal(10, 2)
  totalCost      Decimal         @default(0) @db.Decimal(10, 2)
  customer       Customer        @relation(fields: [customerId], references: [id])
  technician     User?           @relation("TechnicianOrders", fields: [technicianId], references: [id])
  creator        User            @relation("CreatorOrders", fields: [creatorId], references: [id])
  items          WorkOrderItem[]
  report         WorkReport?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model WorkOrderItem {
  id          String    @id @default(cuid())
  orderId     String
  itemId      String?
  description String
  quantity    Int
  unitPrice   Decimal        @db.Decimal(10, 2)
  totalPrice  Decimal        @db.Decimal(10, 2)
  workOrder   WorkOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem? @relation(fields: [itemId], references: [id])
}

model InventoryItem {
  id          String          @id @default(cuid())
  name        String
  sku         String          @unique
  description String?
  quantity    Int             @default(0)
  minQuantity Int             @default(0)
  unitPrice   Decimal         @db.Decimal(10, 2)
  categoryId  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  category    Category?       @relation(fields: [categoryId], references: [id])
  orderItems  WorkOrderItem[]
}

model Category {
  id             String          @id @default(cuid())
  name           String          @unique
  items          InventoryItem[]
}

model WorkReport {
  id              String    @id @default(cuid())
  orderId         String    @unique
  technicianId    String
  diagnosis       String
  actionsTaken    String
  recommendations String?
  images          String[]
  createdAt       DateTime  @default(now())
  workOrder       WorkOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  technician      User      @relation(fields: [technicianId], references: [id])
}

model SystemSettings {
  id             String   @id @default("default")
  companyName    String   @default("Servimaquinas")
  documentId     String?
  address        String?
  phone          String?
  email          String?
  logoUrl        String?
  publicUrl      String?  @default("http://localhost:3000")
  currency       String?  @default("USD")
  currencySymbol String   @default("$")
  taxRate        Decimal  @default(0) @db.Decimal(5, 2)
  updatedAt      DateTime @updatedAt
}

model StoreCategory {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  products    Product[]
}

model Product {
  id          String        @id @default(cuid())
  name        String
  description String?
  price       Decimal       @db.Decimal(10, 2)
  stock       Int           @default(0)
  image       String?
  isPromotion Boolean       @default(false)
  promoPrice  Decimal?      @db.Decimal(10, 2)
  categoryId  String?
  featured    Boolean       @default(false)
  active      Boolean       @default(true)
  category    StoreCategory? @relation(fields: [categoryId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}
