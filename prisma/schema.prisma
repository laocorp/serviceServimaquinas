generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  TECNICO
  RECEPCION
  CLIENTE
}

enum OrderStatus {
  PENDIENTE
  EN_REVISION
  EN_REPARACION
  REPARADO
  ENTREGADO
  CANCELADO
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(RECEPCION)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workOrdersAssigned WorkOrder[] @relation("AssignedTechnician")
  workOrdersCreated  WorkOrder[] @relation("CreatedBy")
  reports            WorkReport[]
  customerProfile    Customer?
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  items       InventoryItem[]
}

model InventoryItem {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  price       Float
  stock       Int      @default(0)
  minStock    Int      @default(5)
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  
  workOrderItems WorkOrderItem[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Customer {
  id             String      @id @default(cuid())
  documentId     String?     // RUC o CI del cliente
  firstName      String
  lastName       String
  phone          String?
  email          String?     @unique
  loyaltyPoints  Int         @default(0)
  isVIP          Boolean     @default(false)
  notes          String?     @db.Text
  
  userId         String?     @unique
  user           User?       @relation(fields: [userId], references: [id])
  
  workOrders     WorkOrder[]
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model WorkOrder {
  id             String      @id @default(cuid())
  trackingCode   String      @unique // Ej. 'SRV-100234'
  
  customerId     String
  customer       Customer    @relation(fields: [customerId], references: [id])
  
  deviceBrand    String
  deviceModel    String
  deviceSerial   String?
  reportedIssue  String      @db.Text
  status         OrderStatus @default(PENDIENTE)
  
  createdById    String
  createdBy      User        @relation("CreatedBy", fields: [createdById], references: [id])
  
  technicianId   String?
  technician     User?       @relation("AssignedTechnician", fields: [technicianId], references: [id])
  
  items          WorkOrderItem[]
  report         WorkReport?

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model WorkOrderItem {
  id              String        @id @default(cuid())
  workOrderId     String
  workOrder       WorkOrder     @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  
  quantity        Int
  priceAtTime     Float

  createdAt       DateTime      @default(now())
}

model WorkReport {
  id               String    @id @default(cuid())
  workOrderId      String    @unique
  workOrder        WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  
  technicianId     String
  technician       User      @relation(fields: [technicianId], references: [id])
  
  diagnosis        String    @db.Text
  actionsTaken     String    @db.Text
  recommendations  String?   @db.Text
  images           String[]  @default([]) // Fotos de evidencia

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model SystemSettings {
  id           String   @id @default("global")
  companyName  String   @default("Servimaquinas")
  documentId   String?  // RUC de la Empresa
  address      String?
  phone        String   @default("")
  email        String?
  publicUrl    String   @default("http://localhost:3000") // URL pública del sistema
  currency     String   @default("USD")
  updatedAt    DateTime @updatedAt
}
